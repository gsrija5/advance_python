a = input()
up=0
lp=0
sp=0
di=0
if len(a) > 7:
    for i in a:
        if i==a.isupper():
            up = up+1
        elif i==a.islower(): 
            lp = lp+1
        elif i==a.isdigit():
            di = di+1
        else:
            sp = sp+1
    if up>0 and lp>0 and sp>0 and di>0:
        print("STRONG")
    else:
        print("WEAK")
else:
    print("weak due to less char")
